<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Casino Fixed</title>

<style>
body {
  font-family: Arial;
  background: #0f1720;
  color: white;
  text-align: center;
}

h1 { color: gold; }

.tabs button {
  padding: 10px;
  margin: 5px;
  background: gold;
  border: none;
  cursor: pointer;
}

.game { display: none; }
.active { display: block; }

.slot {
  width: 60px;
  height: 60px;
  background: black;
  border: 2px solid gold;
  display: inline-flex;
  justify-content: center;
  align-items: center;
  font-size: 30px;
  margin: 5px;
}
</style>
</head>

<body>

<h1>🎰 Casino</h1>
<h3>Balance: $<span id="balance">200</span></h3>

<div class="tabs">
  <button onclick="showGame('slot')">Slot</button>
  <button onclick="showGame('dice')">Dice</button>
</div>

<!-- SLOT -->
<div id="slot" class="game active">
  <div>
    <div class="slot" id="s1">7</div>
    <div class="slot" id="s2">7</div>
    <div class="slot" id="s3">7</div>
  </div>

  Bet: <input id="slotBet" type="number" value="10"><br>
  <button onclick="spin()">SPIN</button>
  <p id="slotResult"></p>
</div>

<!-- DICE -->
<div id="dice" class="game">
  Bet: <input id="diceBet" type="number" value="10"><br>
  Guess (1-6): <input id="guess" type="number"><br>
  <button onclick="rollDice()">ROLL</button>
  <p id="diceResult"></p>
</div>

<script>
let balance = 200;
const symbols = ["7","🍒","🍋","⭐","💎"];

function updateBalance(){
  document.getElementById("balance").innerText = balance;
}

function showGame(id){
  document.querySelectorAll(".game").forEach(g=>g.classList.remove("active"));
  document.getElementById(id).classList.add("active");
}

// SLOT
function spin(){
  let bet = parseInt(document.getElementById("slotBet").value) || 0;

  if(bet <= 0) return alert("Enter valid bet");
  if(bet > balance) return alert("Not enough balance");

  balance -= bet;

  let s1 = symbols[Math.floor(Math.random()*symbols.length)];
  let s2 = symbols[Math.floor(Math.random()*symbols.length)];
  let s3 = symbols[Math.floor(Math.random()*symbols.length)];

  document.getElementById("s1").innerText = s1;
  document.getElementById("s2").innerText = s2;
  document.getElementById("s3").innerText = s3;

  let result = "";

  if(s1===s2 && s2===s3){
    balance += bet*3;
    result = "Win 🎉";
  } else {
    result = "Lose 😢";
  }

  document.getElementById("slotResult").innerText = result;
  updateBalance();
}

// DICE
function rollDice(){
  let bet = parseInt(document.getElementById("diceBet").value) || 0;
  let guess = parseInt(document.getElementById("guess").value);

  if(bet <= 0) return alert("Enter valid bet");
  if(bet > balance) return alert("Not enough balance");
  if(!guess || guess<1 || guess>6) return alert("Enter 1-6");

  balance -= bet;

  let dice = Math.floor(Math.random()*6)+1;

  let result = "";

  if(dice === guess){
    balance += bet*5;
    result = "Win 🎉 Dice: " + dice;
  } else {
    result = "Lose 😢 Dice: " + dice;
  }

  document.getElementById("diceResult").innerText = result;
  updateBalance();
}
</script>

</body>
</html>

