<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>77 Casino Game</title>
  <link rel="stylesheet" href="style.css">
</head>

<body>

<h1>🔥 77 Casino</h1>

<div class="card">
  <div class="balance">Balance: $<span id="balance">300</span></div>

  <div class="slots">
    <div class="slot" id="s1">7</div>
    <div class="slot" id="s2">7</div>
    <div class="slot" id="s3">7</div>
  </div>

  <input type="number" id="bet" value="20">
  <button onclick="play()">PLAY</button>

  <div id="result"></div>
</div>

<script src="script.js"></script>
</body>
</html>
